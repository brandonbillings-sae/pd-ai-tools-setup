# .env.example — copy this file to .env and fill in your credentials.
#
# The install.ps1 script creates this file automatically (Step 4).
# If you are setting up manually, copy this file to .env and edit it.
#
# Where to find each value:
#   GitLab PAT          — https://gitlab.com/-/profile/personal_access_tokens
#                         Scopes needed: read_repository, write_repository, api
#   Docebo credentials  — Docebo Admin > API & SSO > OAuth2 Applications
#   Accredible API key  — Accredible Dashboard > Integrations > API Access
#   Accredible JWT      — Browser DevTools > Network tab > any request > Authorization header
#                         (expires every ~7 days; refresh when tools return 401)

# ── GitLab ───────────────────────────────────────────────────────
GITLAB_EMAIL=your-gitlab-email
GITLAB_PAT=your-personal-access-token

# ── Docebo Production ────────────────────────────────────────────
# SAE:  https://training.sae.org
# PRI:  https://your-lms.docebosaas.com
PROD_URL=https://training.sae.org
PROD_CLIENT_ID=your-client-id
PROD_CLIENT_SECRET=your-client-secret
PROD_USERNAME=your-api-account-email
PROD_PASSWORD=your-api-account-password

# ── Docebo Sandbox ───────────────────────────────────────────────
# SAE:  https://sandbox-training.sae.org
# PRI:  https://your-sandbox.docebosaas.com
SBX_URL=https://sandbox-training.sae.org
SBX_CLIENT_ID=your-sandbox-client-id
SBX_CLIENT_SECRET=your-sandbox-client-secret
SBX_USERNAME=your-api-account-email
SBX_PASSWORD=your-sandbox-password

# ── Accredible ───────────────────────────────────────────────────
# SAE org ID: 98705  |  PRI org ID: 105825
ACCREDIBLE_API_KEY=your-api-key
ACCREDIBLE_ORG_ID=98705
# Refresh from browser DevTools (Network tab > Authorization header) every ~7 days
ACCREDIBLE_JWT=Bearer eyJ...replace-me
